# =========================
# FITSIZ AI Sales Agent — переменные окружения
# Скопируй этот файл в .env и заполни значения
# =========================

# --- Email (Mail.ru для бизнеса) ---
EMAIL_ADDRESS=sales@fitsiz.ru
EMAIL_PASSWORD=app_password_here
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
IMAP_HOST=imap.mail.ru
IMAP_PORT=993

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
AI_MODEL=claude-sonnet-4-6

# --- Уведомления менеджеру (при warm-лиде — email) ---
MANAGER_EMAIL=manager@fitsiz.ru
MANAGER_NAME=Имя Менеджера
MANAGER_EMAIL_CC=                       # опционально, через запятую

# --- Публичный URL дашборда (для deep-link в письмах менеджеру) ---
PUBLIC_BASE_URL=http://127.0.0.1:5173

# --- Персона агента (подставляется в подпись и промпты) ---
AGENT_NAME=Владимир
AGENT_TITLE=Менеджер по работе с партнёрами
AGENT_PHONE=+7 (xxx) xxx-xx-xx
AGENT_SIGNATURE=FITSIZ | fitsiz.ru | fitsiz.app

# --- Лимиты отправки (антиспам) ---
MAX_COLD_EMAILS_PER_DAY=20
MIN_DELAY_BETWEEN_EMAILS_SEC=180
MAX_DELAY_BETWEEN_EMAILS_SEC=420
MIN_REPLY_DELAY_SEC=900
MAX_REPLY_DELAY_SEC=2700
INBOX_CHECK_INTERVAL_SEC=600

# --- Режим работы ---
# false = модерация (AI делает черновики, человек утверждает)
# true  = автоматическая отправка
# Дефолт; в рантайме переключается тумблером в Settings (хранится в БД).
AUTO_SEND=false
# Авто-передача warm-лида менеджерам (тоже тумблер в Settings)
AUTO_TRANSFER_TO_MANAGER=false

# --- Auth (вход в дашборд) ---
# ОБЯЗАТЕЛЬНО задайте свой секрет в проде (любая длинная случайная строка)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_DAYS=7
AUTH_COOKIE_NAME=fitsiz_session
# true, если дашборд за HTTPS
AUTH_COOKIE_SECURE=false

# --- База данных ---
DATABASE_URL=sqlite:///./data/fitsiz_agent.db

# --- API (FastAPI) ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
